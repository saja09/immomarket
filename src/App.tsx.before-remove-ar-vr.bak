type Property = {
  id: number
  title: string
  city: string
  district: string
  area: number
  rooms: number
  bathrooms: number
  kitchens: number
  price: string
  image: string
  gallery: string[]
  description: string
}

type SavedUser = {
  fullName: string
  identifier: string
  password: string
}

type SortMode = "cheap" | "luxury" | "best" | null

type ParsedSearch = {
  raw: string
  normalized: string
  propertyType: "شقة" | "فيلا" | "منزل" | "استوديو" | null
  city: string | null
  district: string | null
  minPriceDh: number | null
  maxPriceDh: number | null
  maxArea: number | null
  minArea: number | null
  sortMode: SortMode
  supportDh: number | null
  explanation: string[]
}

